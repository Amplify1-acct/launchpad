# ── Social OAuth Env Vars ─────────────────────────────────────────────────────
# Add these to Vercel: https://vercel.com/team_AmplifyForLawyers/launchpad/settings/environment-variables

NEXT_PUBLIC_APP_URL=https://www.exsisto.ai

# Facebook / Instagram OAuth
# Create app at: https://developers.facebook.com/apps/
# Add "Facebook Login" product, set redirect URI to:
#   https://www.exsisto.ai/api/auth/facebook/callback
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# TikTok for Business OAuth
# Create app at: https://developers.tiktok.com/
# Add redirect URI: https://www.exsisto.ai/api/auth/tiktok/callback
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
